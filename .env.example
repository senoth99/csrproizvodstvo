# Локально (без Postgres): файл рядом с schema.prisma.
# socket_timeout — ждать разблокировки SQLite при migrate (остановите npm run dev / PM2 перед migrate deploy).
DATABASE_URL=file:./dev.db?socket_timeout=30
# Фото отчётов (вне public, переживает деплой). Локально по умолчанию prisma/uploads; на VPS: file:/data/app/production.db → /data/app/uploads
# UPLOADS_DIR=/data/app/uploads
# После git clone или смены schema: npm install && npm run db:push && npm run prisma:seed
# Один раз всё поднять: npm run dev:fresh
# Схема обязательна (http:// или https://). Вариант «localhost:3000» без схемы ломал редиректы /api/login/token → 500.
APP_URL=http://localhost:3000
# Короткий git SHA, подставляется в deploy.sh перед `npm run build` — на /telegram/login видно, какой билд отдал сервер.
# Вручную: export NEXT_PUBLIC_BUILD_REF=$(git rev-parse --short HEAD) && npm run build
# NEXT_PUBLIC_BUILD_REF=
SESSION_SECRET=change_me_super_long_random_secret
# Для локального входа по http://127.0.0.1 или http://192.168.x.x (без HTTPS) оставьте false или явно HTTPS в APP_URL
SESSION_COOKIE_SECURE=false

# Telegram (Mini App initData + вход из обычного браузера через бота)
# 1) BotFather → /newbot → TELEGRAM_BOT_TOKEN
# 2) NEXT_PUBLIC_TELEGRAM_BOT_USERNAME — username бота без @
# 3) TELEGRAM_WEBHOOK_SECRET — произвольная длинная строка (secret_token в setWebhook)
# 4) Webhook: https://ВАШ_ДОМЕН/api/telegram/webhook (см. README или инструкцию в чате)
TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
# На VPS, где api.telegram.org недоступен: HTTPS_PROXY=socks5h://127.0.0.1:1080 (curl подхватит при деплое)
# SKIP_TELEGRAM_WEBHOOK=1 — не вызывать setWebhook в deploy.sh (настроить вручную позже)
# Резервный super-admin без строки в allowlist: совпадение @username ИЛИ числового id Telegram (удобно, если в TG нет @username)
TELEGRAM_ADMIN_USERNAME=
TELEGRAM_ADMIN_TELEGRAM_ID=
# Суперадмин для входа по телефону/паролю (7XXXXXXXXXX или +7…). Авто-одобрение и роль SUPER_ADMIN при регистрации.
SUPER_ADMIN_PHONE=
# Опционально: другой контакт только для страницы «нет доступа» (виден клиенту)
NEXT_PUBLIC_TELEGRAM_CONTACT=

# Cron: напоминания о смене завтра в 21:00 МСК (scripts/shift-reminders-cron.sh или PM2 shift-reminders)
CRON_SECRET=

# Web Push (browser notifications). Сгенерировать ключи: npx tsx scripts/generate-vapid-keys.ts
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Production: при true десктоп без сессии → /access-denied. Оставьте false, чтобы входить с ПК через /login.
# AUTH_DESKTOP_NO_SESSION_ACCESS_DENIED=false

# --- Локальный вход БЕЗ бота (только development) ---
NEXT_PUBLIC_TELEGRAM_AUTH_DEV=true
TELEGRAM_ALLOW_DEV_LOGIN=true
# Виртуальный Telegram-профиль для сессии dev (не ходит в Telegram API):
TELEGRAM_DEV_TELEGRAM_ID=918273645
TELEGRAM_DEV_USERNAME=
TELEGRAM_DEV_FIRST_NAME=Локальная
TELEGRAM_DEV_LAST_NAME=сессия
# SUPER_ADMIN | ADMIN | EMPLOYEE (по умолчанию SUPER_ADMIN)
TELEGRAM_DEV_ROLE=SUPER_ADMIN

# Если в базе нет пользователей с ролью EMPLOYEE и нужны тестовые строки не в режиме development:
# MANAGER_DEMO_USERS_ON_EMPTY=1

# ---------------------------------------------------------------------------
# Production (сервер: systemd, Docker, VPS)
# ---------------------------------------------------------------------------
# NODE_ENV задаёт процесс запуска (в Docker уже production). Перед первым прод-запуском:
#   npm ci && npm run build && npm run prisma:deploy && npm start
# (или образ из Dockerfile — entrypoint выполнит db push для SQLite).
#
# Обязательно смените секрет и URL:
# APP_URL=https://your-domain.example
# SESSION_SECRET=<длинная случайная строка, не из примера>
# SESSION_COOKIE_SECURE=true
#
# Dev-обход входа через Telegram должен быть отключён на сервере:
# NEXT_PUBLIC_TELEGRAM_AUTH_DEV=false
# TELEGRAM_ALLOW_DEV_LOGIN=false
# APP_TEST_MODE=false
#
# Обязательно на сервере:
# SUPER_ADMIN_PHONE=7993… (суперадмин по телефону)
# VAPID_PUBLIC_KEY / VAPID_PRIVATE_KEY (push-уведомления)
# UPLOADS_DIR=/data/app/uploads (если DATABASE_URL=file:/data/app/production.db)
#
# Telegram: заполните TELEGRAM_BOT_TOKEN, NEXT_PUBLIC_TELEGRAM_BOT_USERNAME, TELEGRAM_WEBHOOK_SECRET;
# установите webhook на https://your-domain.example/api/telegram/webhook с secret_token.
#
# Текущая схема Prisma — SQLite. На сервере укажите путь на диск с постоянным томом:
# DATABASE_URL=file:/data/app/production.db
# Если раньше делали только `db push` и `migrate deploy` падает с P3005 («schema is not empty»),
# `./deploy.sh` и Docker entrypoint сами делают `migrate resolve --applied` и повторный deploy.
# (создайте каталог и права на запись пользователю Node; в Docker см. том на /data).
# Postgres понадельник требует смены provider в prisma/schema.prisma и миграций под выбранный движок.

